# Database
DATABASE_URL="postgresql://user:password@localhost:5432/signalhub?schema=public"

# Clerk (get from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk URLs — paths only (work on localhost and when you host the project).
# Auth is still 100% Clerk; these just keep sign-in/sign-up on YOUR domain instead of accounts.dev.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# LiveKit (get from https://cloud.livekit.io or self-host)
# Token API uses these; never expose the secret to the client.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Optional: WebSocket URL for the client (e.g. wss://your-project.livekit.cloud)
NEXT_PUBLIC_LIVEKIT_URL=
